# Отключаем автоподбор файлов и вывод содержимого директорий
Options -MultiViews -Indexes

# Настройки роутинга для Next.js static export
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Реальный файл или папка — отдаём как есть
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # .html-версия существует — отдаём её
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Защита паролем на всё
AuthType Basic
AuthName "Restricted Access"
AuthUserFile /home/c/citymed/kosmo-test12/public_html/.htpasswd
Require valid-user

# Гарантирует показ стандартного диалога входа, а не страницу ошибки
ErrorDocument 401 default
