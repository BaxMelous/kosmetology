# СитиМед Эстетика — конфигурация Apache
# Для Next.js static export (output: 'export' + trailingSlash: true)

# Включаем index.html как документ по умолчанию для всех директорий
DirectoryIndex index.html

# Разрешаем доступ ко всем файлам
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Если запрошенный путь — директория без index.html, пробуем index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)/$ $1/index.html [L]

  # Если запрошенный путь без слеша — это директория с index.html — редирект на слеш
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*[^/])$ $1/ [R=301,L]
</IfModule>

# Правильные MIME-типы
AddType video/mp4 .mp4
AddType image/webp .webp
AddType image/svg+xml .svg

# Кеширование статики
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Сжатие
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
